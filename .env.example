# ─────────────────────────────────────────────────────────────
# Arceval — environment configuration template
# Copy this file to `.env` and fill in the values below.
# Never commit your real `.env` — it is gitignored by default.
# ─────────────────────────────────────────────────────────────

# REQUIRED — Choose your AI provider: "anthropic", "openai", or "gemini"
ARCEVAL_PROVIDER=anthropic

# ─────────────────────────────────────────────────────────────
# API KEYS — Set the key for your chosen provider
# ─────────────────────────────────────────────────────────────

# Anthropic Claude (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI GPT (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-key-here

# Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-key-here

# ─────────────────────────────────────────────────────────────
# MODEL CONFIGURATION
# ─────────────────────────────────────────────────────────────

# OPTIONAL — Override the model name. If empty, uses provider default:
#   anthropic → claude-sonnet-4-5
#   openai    → gpt-4o
#   gemini    → gemini-2.0-flash
ARCEVAL_MODEL=

# OPTIONAL — Maximum output tokens the AI may generate. Default: 4096.
ARCEVAL_MAX_TOKENS=4096

# OPTIONAL — OpenAI base URL (for Azure OpenAI or compatible APIs like Ollama)
# Example: https://your-resource.openai.azure.com/
OPENAI_BASE_URL=

# ─────────────────────────────────────────────────────────────
# ANALYSIS LIMITS
# ─────────────────────────────────────────────────────────────

# OPTIONAL — Hard cap on characters of project context sent to AI. Default: 60000.
ARCEVAL_MAX_CONTEXT_CHARS=60000

# OPTIONAL — Maximum number of sampled source files to include. Default: 5.
ARCEVAL_MAX_SOURCE_FILES=5

# OPTIONAL — Truncate individual files to this many lines. Default: 300.
ARCEVAL_MAX_FILE_LINES=300

# OPTIONAL — Skip files larger than this many KB. Default: 30.
ARCEVAL_MAX_FILE_SIZE_KB=30

# ─────────────────────────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────────────────────────

# OPTIONAL — Log level: DEBUG, INFO, WARNING, ERROR. Default: INFO.
ARCEVAL_LOG_LEVEL=INFO
